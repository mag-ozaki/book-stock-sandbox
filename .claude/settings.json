{
  "permissions": {
    "allow": [
      "Write(**)",
      "Bash(mkdir *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(sleep *)",
      "Bash(docker compose up -d)",
      "Bash(docker compose run *)",
      "Bash(docker compose exec laravel php artisan migrate --env=testing)",
      "Bash(docker compose exec laravel php artisan test)",
      "Bash(docker compose exec laravel php artisan test *)",
      "Bash(docker compose exec -e XDEBUG_MODE=coverage laravel php artisan test*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push *--force*)",
      "Bash(git push *-f)",
      "Bash(git push *-f *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git checkout -- *)"
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-protected-branch-push.sh"
          }
        ]
      }
    ]
  }
}
